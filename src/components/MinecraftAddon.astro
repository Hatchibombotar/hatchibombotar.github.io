---

const {href, title, image} = Astro.props
---
<a
    class="group cursor-pointer"
    target="_blank"
    href={href}
>
    <img src={image} class="mb-2 group-hover:brightness-105" />
    <h2
        class="font-semibold mt-1 group-hover:underline underline-offset-4 group-hover:text-green-700"
    >
        {title}
    </h2>
</a>
